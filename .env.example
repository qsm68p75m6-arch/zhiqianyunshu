# ==============================================================================
# 智迁云枢 · 环境变量配置示例
# 使用方法：cp .env.example .env，然后填入真实配置值
# 注意：.env 文件已加入 .gitignore，请勿将真实密鑰提交到代码仓库！
# ==============================================================================


# ------------------------------------------------------------------------------
# LLM 大模型配置
# ------------------------------------------------------------------------------

# LLM 提供者，可选值：zhipu | openai | claude | deepseek | qwen
LLM_PROVIDER=zhipu

# 对应提供者的 API Key（必填）
LLM_API_KEY=<your-key>

# 是否启用 Mock LLM（本地开发调试时可设为 true，不消耗 API 额度）
MOCK_LLM=false

# LLM 请求超时时间（毫秒）
LLM_TIMEOUT_MS=30000

# LLM 最大 Token 数
LLM_MAX_TOKENS=4096


# ------------------------------------------------------------------------------
# 数据库配置（MySQL）
# ------------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=3306
DB_NAME=zhiqianyunshu
DB_USERNAME=root
DB_PASSWORD=<your-db-password>


# ------------------------------------------------------------------------------
# RAG 微服务配置（Python FastAPI）
# ------------------------------------------------------------------------------

# RAG 服务地址
RAG_SERVICE_URL=http://127.0.0.1:8001

# RAG 检索返回的最大文档块数量
RAG_TOP_K=5

# 混合检索权重
RAG_VECTOR_WEIGHT=0.7
RAG_BM25_WEIGHT=0.3


# ------------------------------------------------------------------------------
# Spring Boot 服务配置
# ------------------------------------------------------------------------------

SERVER_PORT=8080
JWT_SECRET=<your-jwt-secret-key-at-least-256-bits>
JWT_EXPIRATION_MS=86400000


# ------------------------------------------------------------------------------
# 其他配置
# ------------------------------------------------------------------------------

LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173